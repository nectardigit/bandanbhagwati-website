# ============================================================
#  PRODUCTION .env  —  copy to ".env" on the server and fill in
#  Never commit the real .env. Generate APP_KEY on the server.
# ============================================================

APP_NAME="Bandan Bhagwati"
APP_ENV=production
APP_KEY=                      # run: php artisan key:generate
APP_DEBUG=false               # MUST be false in production (no stack traces / secrets)
APP_URL=https://bandanbhagwati.com
SITE_URL=https://bandanbhagwati.com

# --- Force HTTPS + secure cookies ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true     # cookies only over HTTPS
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=warning              # not "debug" in prod

# --- Database (use a dedicated, least-privilege MySQL user, NOT root) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bandan
DB_USERNAME=bandan_app         # NOT root
DB_PASSWORD=                   # strong unique password

# --- Cache / Queue ---
CACHE_STORE=file
QUEUE_CONNECTION=database

# --- Admin seed (used only by the seeder; change after first login) ---
ADMIN_EMAIL=admin@bandanbhagwati.com
ADMIN_PASSWORD=                # strong unique password — never leave blank/"password"

# --- Mail (set real SMTP before relying on contact/enquiry emails) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@bandanbhagwati.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- File manager / uploads ---
FILESYSTEM_DISK=public
