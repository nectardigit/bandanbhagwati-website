<IfModule mod_rewrite.c>
    RewriteEngine On
    # Serve the Laravel app from the public/ subfolder (docroot is the project root).
    RewriteCond %{REQUEST_URI} !^/public
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block direct access to sensitive files just in case
<FilesMatch "^\.env|composer\.(json|lock)|\.gitignore">
    Require all denied
</FilesMatch>
